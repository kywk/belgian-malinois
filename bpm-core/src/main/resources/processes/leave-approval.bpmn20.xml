<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://bpm.com/leave">

  <process id="leave-approval" name="請假審核流程" isExecutable="true">

    <startEvent id="start" flowable:initiator="initiator"
                flowable:formKey="leave-request"/>

    <sequenceFlow id="flow1" sourceRef="start" targetRef="managerReview"/>

    <userTask id="managerReview" name="主管審核"
              flowable:assignee="${orgService.getDirectManager(initiator)}"
              flowable:formKey="leave-review">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${notifyTaskListener}"/>
      </extensionElements>
    </userTask>

    <sequenceFlow id="flow2" sourceRef="managerReview" targetRef="gw1"/>

    <exclusiveGateway id="gw1" name="審核結果" default="flowReturn"/>

    <sequenceFlow id="flowApproved" sourceRef="gw1" targetRef="endApproved">
      <conditionExpression>${approved == true}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flowRejected" sourceRef="gw1" targetRef="endRejected">
      <conditionExpression>${rejected != null &amp;&amp; rejected == true}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flowReturn" sourceRef="gw1" targetRef="applicantRevision"/>

    <userTask id="applicantRevision" name="申請者補件"
              flowable:assignee="${initiator}"
              flowable:formKey="leave-request">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${notifyTaskListener}"/>
      </extensionElements>
    </userTask>

    <sequenceFlow id="flowResubmit" sourceRef="applicantRevision" targetRef="managerReview"/>

    <endEvent id="endApproved" name="核准"/>
    <endEvent id="endRejected" name="拒絕"/>

  </process>
</definitions>
